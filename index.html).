<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Xác nhận</title>
</head>
    <body style="text-align: center; font-family: Arial; margin-top: 100px;">
        <h1 style="font-size: 30px;">Anh Huy thích nhất là gì?</h1>
        
        <select id="answer" style="font-size: 20px; padding: 10px;">
            <option value="A">A: Game</option>
            <option value="B">B: Gái</option>
            <option value="C">C: Câu cá</option>
            <option value="D">D: Nuôi cá</option>
        </select>
        
        <br><br>
        
        <button onclick="checkAnswer()" style="font-size: 20px; padding: 10px 20px;">Xác nhận</button>


    <script>
        function checkAnswer() {
            var choice = document.getElementById("answer").value;
            if (choice == "B") {
                window.location.href = "/content";
            } else {
                alert("Sai rồi! Thử lại đi.");
            }
        }
    </script>
</body><div style="text-align: center; margin-top: 50px;">
    <video width="80%" controls>
        <source src="{{ url_for('static', filename='d.mp4') }}" type="video/mp4">
    </video>
</div>

</html>
